# ============================================================
# nanigashi 自動執筆システム 環境変数設定ファイル
# ============================================================
# このファイルをコピーして ".env" という名前で保存し、
# 各値を実際の値に書き換えてください。
# .env ファイルは絶対にGitにコミットしないでください。
# ============================================================

# --- Claude API ---
# Anthropic コンソール (https://console.anthropic.com) で取得
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- WordPress ---
# WP_URL: WordPressサイトのURL（末尾スラッシュなし）
WP_URL=https://your-blog.com
# WP_USER: WordPressのログインユーザー名
WP_USER=your_wp_username
# WP_APP_PASSWORD: WordPress管理画面 → ユーザー → プロフィール → アプリケーションパスワード で生成
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- GitHub ---
# GH_PAT: GitHubの個人アクセストークン（Fine-grained PAT）
# 必要なスコープ: repo, project（read/write）
# https://github.com/settings/tokens で生成
GH_PAT=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
